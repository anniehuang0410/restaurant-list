<!-- ./views/index.handlebars -->
<!-- search bar -->
<div class="container search-bar">
  <div class="search-bar-outer">
    <div class="search-bar-inner">
      <form action="/search">
        <h4 class="mb-2">尋找餐廳：</h4>
        <div class="input-group">
          <input type="text" name="keyword" value="{{keyword}}" class="form-control" placeholder="輸入餐廳、分類"
            aria-label="Restaurant Name..." value="" aria-describedby="search-button">
          <div class="input-group-append">
            <button class="btn btn-major" type="submit" id="search-button"><i class="fas fa-search"></i></button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- restaurant list -->
<div class="container mt-5">
  <div class="row">
    <div class="col-md-9 col-12 mx-auto">
      <div class="row row-cols-sm-3 mb-3">
        <!-- render restaurants -->
        {{#each restaurant}}
        <div>
          <a href="./restaurants/{{this._id}}" class="text-secondary">
            <div class="card mt-3 mb-1">
              <img class="card-img-top" src="{{this.image}}" alt="{{this.name}}">
              <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                  <h6 class="card-title mb-1 py-1">{{this.name}}</h6>
                  <span class="font-weight-normal ">
                    <i class="fas fa-star fa-xs"></i>
                    {{this.rating}}
                  </span>
                </div>
                <div class="restaurant-category mb-1">
                  <i class="fas fa-utensils pr-2"></i> {{this.category}}
                </div>
              </div>
            </div>
          </a>
          <div class="d-flex justify-content-end">
            <a href="./restaurants/{{this._id}}" class="p-1 link-primary">看更多...</a>
            <a href="./restaurants/{{this._id}}/edit" class="p-1 mx-1 link-secondary">修改</a>
            <form action="./restaurants/{{this._id}}/delete" method="POST">
              <button type="submit" class="py-0 px-1 ml-1 btn btn-secondary">刪除</button>
            </form>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </div>
  <div class="d-flex justify-content-center py-5">
    <a class="btn btn-primary m-2" href="./restaurants/new">新增餐廳</a>
  </div>
</div>